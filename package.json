{
  "name": "Moonlit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "reverse-port": "adb reverse tcp:8081 tcp:8081",
    "restart": "yarn cache clean && yarn reinstall && yarn start --reset-cache",
    "codegen-android": "cd ./android && ./gradlew generateCodegenArtifactsFromSchema",
    "pod-reinstall": "cd ./ios && rm -rf ~/Library/Caches/CocoaPods && rm -rf Pods && bundle exec pod install --repo-update && cd ..",
    "postinstall": "patch-package && git config core.hooksPath .githooks",
    "reinstall": "rm -rf node_modules && watchman watch-del-all && yarn && yarn postinstall && yarn pod-reinstall"
  },
